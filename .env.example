# ============================================================
#  Azzam — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# ---- قاعدة البيانات (إلزامي) ----
# للتطوير المحلي: استخدم SQLite
# DATABASE_URL="file:/home/z/my-project/db/custom.db"
#
# للإنتاج (Vercel, Render, Railway, إلخ): استخدم PostgreSQL من Neon / Supabase / Vercel Postgres
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ---- سر JWT لتوقيع الجلسات (إلزامي) ----
# سلسلة عشوائية طويلة (32 حرفاً على الأقل)
# لتوليد قيمة آمنة: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ============================================================
#  بيانات اعتماد Z.ai (إلزامي على Vercel — مطلوب لـ GLM-4.5 المجاني)
# ============================================================
# هذه البيانات تُمرَّر عبر متغيرات البيئة بدلاً من ملف .z-ai-config
# احصل عليها من حسابك على Z.ai أو من البيئة المحلية:
#   cat /etc/.z-ai-config
#
# ZAI_BASE_URL="https://internal-api.z.ai/v1"
# ZAI_API_KEY="Z.ai"
# ZAI_TOKEN="<your-jwt-token-from-z-ai-config>"
# ZAI_USER_ID="<your-user-id-from-z-ai-config>"
# ZAI_CHAT_ID="<your-chat-id-from-z-ai-config>"

# ============================================================
#  مفاتيح الذكاء الاصطناعي الأخرى (اختيارية — لا تضعها هنا)
# ============================================================
# OpenAI / Anthropic / Gemini / Ollama:
#   لا تُضاف هنا — تُضاف من داخل التطبيق بعد تسجيل الدخول
#   صفحة "إعدادات API" → تُحفظ في قاعدة البيانات لكل مستخدم
# ============================================================
